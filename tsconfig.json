{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "skipLibCheck": true,

    /* الاستيراد والبناء */
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true, // نخبر الـ TS ألا ينتج ملفات بنفسه، ويترك البناء لـ Vite
    "jsx": "react-jsx",

    /* الفحص الصارم للأخطاء */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true
  },
  "include": ["assets/src/**/*", "src/**/*"] // نحدد مجلدات الأكواد الخاصة بمشروعك ليقوم بفحصها
}
